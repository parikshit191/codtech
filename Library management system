#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Book
{
    int id;
    char title[100];
    char author[100];
    struct Book *next;
};

struct Book *head = NULL;

// Add Book
void addBook()
{
    struct Book *newBook, *temp;

    newBook = (struct Book *)malloc(sizeof(struct Book));

    printf("\nEnter Book ID: ");
    scanf("%d", &newBook->id);

    getchar();

    printf("Enter Book Title: ");
    gets(newBook->title);

    printf("Enter Author Name: ");
    gets(newBook->author);

    newBook->next = NULL;

    if (head == NULL)
    {
        head = newBook;
    }
    else
    {
        temp = head;
        while (temp->next != NULL)
            temp = temp->next;

        temp->next = newBook;
    }

    printf("\nBook Added Successfully!\n");
}

// Display Books
void displayBooks()
{
    struct Book *temp = head;

    if (head == NULL)
    {
        printf("\nLibrary is Empty.\n");
        return;
    }

    printf("\n------ Library Books ------\n");

    while (temp != NULL)
    {
        printf("\nBook ID : %d", temp->id);
        printf("\nTitle   : %s", temp->title);
        printf("\nAuthor  : %s\n", temp->author);

        temp = temp->next;
    }
}

// Search Book
void searchBook()
{
    int id;
    struct Book *temp = head;

    printf("\nEnter Book ID to Search: ");
    scanf("%d", &id);

    while (temp != NULL)
    {
        if (temp->id == id)
        {
            printf("\nBook Found!\n");
            printf("Book ID : %d\n", temp->id);
            printf("Title   : %s\n", temp->title);
            printf("Author  : %s\n", temp->author);
            return;
        }

        temp = temp->next;
    }

    printf("\nBook Not Found!\n");
}

// Delete Book
void deleteBook()
{
    int id;
    struct Book *temp = head;
    struct Book *prev = NULL;

    printf("\nEnter Book ID to Delete: ");
    scanf("%d", &id);

    while (temp != NULL && temp->id != id)
    {
        prev = temp;
        temp = temp->next;
    }

    if (temp == NULL)
    {
        printf("\nBook Not Found.\n");
        return;
    }

    if (prev == NULL)
    {
        head = temp->next;
    }
    else
    {
        prev->next = temp->next;
    }

    free(temp);

    printf("\nBook Deleted Successfully!\n");
}

int main()
{
    int choice;

    while (1)
    {
        printf("\n================================");
        printf("\n LIBRARY MANAGEMENT SYSTEM");
        printf("\n================================");
        printf("\n1. Add Book");
        printf("\n2. Display Books");
        printf("\n3. Search Book");
        printf("\n4. Delete Book");
        printf("\n5. Exit");
        printf("\nEnter Choice: ");
        scanf("%d", &choice);

        switch (choice)
        {
        case 1:
            addBook();
            break;

        case 2:
            displayBooks();
            break;

        case 3:
            searchBook();
            break;

        case 4:
            deleteBook();
            break;

        case 5:
            printf("\nThank You!\n");
            exit(0);

        default:
            printf("\nInvalid Choice!\n");
        }
    }

    return 0;
}
